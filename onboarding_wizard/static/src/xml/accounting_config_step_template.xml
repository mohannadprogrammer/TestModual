<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Step 5: Accounting Configuration -->
    <t t-name="onboarding_wizard.AccountingConfigStep">
        <div class="wizard_step accounting_config_step">
            <h2>Accounting Configuration</h2>

            <!-- Fiscal Localization & Chart of Accounts -->
            <div class="accounting_section">
                <h3>Fiscal Configuration</h3>

                <div class="form_row">
                    <div class="form_group flex-1">
                        <label>Fiscal Localization *</label>
                        <select 
                            class="form_control" 
                            t-model="state.currentlocalization">
                            <option value="">Select Fiscal Localization</option>
                            <t t-foreach="state.countries" t-as="loc" t-key="loc.id">
                                <option t-attf-value="{{loc.id}}" t-esc="loc.name" />
                            </t>
                        </select>
                    </div>
                    <div class="form_group flex-1">
                        <label>Chart of Accounts *</label>
                        <button 
                            class="btn btn-link p-0"
                            t-on-click="openChartOfAccounts"
                        >
                            Open Chart of Accounts
                            <t t-if="state.chartOfAccounts">
                                <i class="fa fa-check text-success"></i>
                            
                            </t>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ZATCA Configuration -->
            <div class="zatca_section">
                <h3>ZATCA Configuration (Tax Authority - Saudi Arabia)</h3>
                
                <div class="form_row">
                    <div class="form_group flex-1">
                        <!-- //select to enable/disable ZATCA configuration of the option (
                            	
                                sandbox	Sandbox	
                                preprod	Simulation (Pre-Production)	
                                prod	Production
                        ) -->
                        <label> ZATCA Integration mode</label>
                        <select 
                            class="form_control"
                            t-model="state.zatcaApi"
                            t-on-change="(e) => this.handleInputChange('zatcaApi', e.target.value === 'true')"
                            >
                            
                            <option value="sandbox">Sandbox</option>
                            <option value="preprod">	Simulation (Pre-Production)	</option>
                            <option value="true">Production</option>
                        </select>
                    </div>
                </div>

               
            </div>

            <!-- Payment Methods -->
            <div class="payment_methods_section">
                <h3>Payment Methods</h3>

                <div class="add_payment_method_form">
                    <button 
                        class="btn btn-primary w-100"
                        t-on-click="() => this.addPaymentMethodInAction()">
                        <i class="fa fa-plus"></i> Add Payment Method
                    </button>
                </div>

                <t t-if="state.paymentMethods.length > 0">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="state.paymentMethods" t-as="method" t-key="method.id">
                                <td><t t-esc="method.name" /></td>
                                <td><t t-esc="method.code" /></td>
                                <td>
                                    <button 
                                        class="btn btn-sm btn-danger"
                                        t-on-click="() => this.removePaymentMethod(method.id)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </t>
            </div>

            <!-- Bank Accounts -->
            <div class="bank_accounts_section">
                <h3>Bank Accounts</h3>

                <div class="add_bank_account_form">
                    

                    <div class="form_row">
                        
                        <div class="form_group" style="align-self: flex-end;">
                            <button 
                                class="btn btn-primary w-100"
                                t-on-click="() => this.addBankAccountinAction()">
                                <i class="fa fa-plus"></i> Add Account (Full form)
                            </button>
                        </div>
                    </div>
                </div>

                <t t-if="state.bankAccounts.length > 0">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Account Number</th>
                                <th>Bank</th>
                                <th>Currency</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="state.bankAccounts" t-as="account" t-key="account.id">
                                <td><t t-esc="account.name" /></td>
                                <td><t t-esc="account.account_number" /></td>
                                <td><t t-esc="account.bank_name" /></td>
                                <td><t t-esc="account.currency_id" /></td>
                                <td>
                                    <button 
                                        class="btn btn-sm btn-danger"
                                        t-on-click="() => this.removeBankAccount(account.id)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </t>
            </div>

            <!-- Taxes Configuration -->
            <div class="taxes_section">
                <h3>Taxes</h3>
                <p class="text-muted">Tax configuration will be set up based on the selected fiscal localization.</p>
                <div class="alert alert-info">
                    <strong>Note:</strong> Default taxes for <t t-esc="state.fiscalLocalization || 'selected region'" /> will be automatically created.
                </div>
            </div>
            <div class="form_actions">
                <button class="btn btn-outline-secondary" t-on-click="props.onPrevious">
                    ← Previous
                </button>
                <button
                    class="btn btn-primary"
                    t-on-click="() => {
                    props.onNext();
                    }"
                >
                    Next →
                </button>
            </div>
        </div>
    </t>

</templates>
