<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Step 7: Final Dashboard -->
    <t t-name="onboarding_wizard.FinalDashboardStep">
        <div class="wizard_step final_dashboard_step">
            <div class="completion_message">
                <h2>🎉 You're All Set!</h2>
            </div>

            <div class="dashboard_stats_grid">
                <div class="stat_card">
                    <div class="stat_value">
                        <t t-esc="state.completionScore" />%
                    </div>
                    <p class="stat_label">Setup Completion</p>
                    <div class="stat_progress">
                        <div
                            class="stat_progress_fill"
                            t-attf-style="width: {{ state.completionScore or 75 }}%"
                        />
                    </div>
                </div>

                <div class="stat_card">
                    <div class="stat_value" t-out="state.totalModules" />
                    <p class="stat_label">Modules Installed</p>
                </div>

                <div class="stat_card">
                    <div class="stat_value" t-esc="state.totalUsers" />
                    <p class="stat_label">Team Members</p>
                </div>

                <div class="stat_card">
                    <div class="stat_value">
                        <t t-if="state.emailStatus === 'configured'">
                            ✓
                        </t>
                        <t t-else="">
                            ✗
                        </t>
                    </div>
                    <p class="stat_label">Email Configuration</p>
                </div>
            </div>

            <div class="next_steps_section">
                <h3>What's Next?</h3>
                <ul class="next_steps_list">
                    <li>📧 Configure email settings for notifications</li>
                    <li>👥 Invite more team members</li>
                    <li>📊 Create your first project or sale order</li>
                    <li>🔧 Customize workflows for your business</li>
                </ul>
            </div>

            <div class="final_actions">
                <button class="btn btn-success btn-lg" t-on-click="props.onComplete">
                    🎉 Complete Setup &amp; Go to Dashboard
                </button>
            </div>
        </div>
    </t>

</templates>
